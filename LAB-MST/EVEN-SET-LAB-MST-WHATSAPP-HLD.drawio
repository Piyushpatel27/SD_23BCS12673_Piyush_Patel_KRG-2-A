        <mxCell id="KBRIS76X-1Ge197PzryG-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="DESIGN A&amp;nbsp; WHATSAPP SYSTEM with&lt;div&gt;USERSERVICE&lt;/div&gt;&lt;div&gt;CHATSERVICE&lt;/div&gt;&lt;div&gt;GROUP SERVICE&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;DAU-1.5m+&lt;/div&gt;&lt;div&gt;SPECIFY THE TYPE OF CONNECTION USED IN DESIGN&lt;/div&gt;&lt;div&gt;DETERMINE HOW THE DESIGNING WILL BE DONE FOR LAST SEEN FUNCTIONALITY&lt;/div&gt;&lt;div&gt;IMPLEMENT CDC PIPELINE IN SAME ARCHITECTURE&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="700" x="530" y="10" as="geometry" />
        </mxCell>
        <mxCell id="KBRIS76X-1Ge197PzryG-16" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;CORE ENTITIES&lt;/h1&gt;&lt;div&gt;1. USER&lt;/div&gt;&lt;div&gt;2. MESSAGE&lt;/div&gt;&lt;div&gt;3. GROUP&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="240" x="150" y="720" as="geometry" />
        </mxCell>
        <mxCell id="KBRIS76X-1Ge197PzryG-17" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;FUNCTIONAL REQUIREMENTS&lt;/h1&gt;&lt;div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. USER SHOULD BE ABLE TO REGISTER/SIGNUP&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;2. USER SHOULD BE ABLE TO SEND ONE-ONE MESSAGE&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;3.USER SHOULD BE ABLE TO PERFORM GROUP MESSAGING&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;4.USER SHOULD BE ABLE TO SHARE TEXT AND MEDIA FILES&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;5. USER SHOULD BE ABLE TO CHECK MESSAGE DELIVERY STATUS&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="420" x="100" y="355" as="geometry" />
        </mxCell>
        <mxCell id="KBRIS76X-1Ge197PzryG-18" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;API ENDPOINTS&lt;/h1&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. REGISTER USER&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;POST: &quot;USER/REGISTER&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; USERNAME,&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;EMAIL,&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;MOBILE_NUMBER&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. RETRIEVE A USER&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;GET: &quot;/USER / {USER_ID}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="350" width="240" x="1925" y="270" as="geometry" />
        </mxCell>
        <mxCell id="KBRIS76X-1Ge197PzryG-21" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;/h1&gt;&lt;div&gt;3. SEND MESSAGE TO USER&lt;/div&gt;&lt;div&gt;&amp;nbsp;&quot;WS/MESSAGE/ {USER_ID}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. GET GROUPS FOR&amp;nbsp; USER&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;GET :&amp;nbsp; &quot;GROUPS/ {USER_ID}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="210" x="2250" y="285" as="geometry" />
        </mxCell>
        <mxCell id="KBRIS76X-1Ge197PzryG-22" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;NON FUNCTIONAL REQUIREMENTS&lt;/h1&gt;&lt;div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. DAU--&amp;gt; 1.5MILLION+&lt;/span&gt;&lt;div&gt;2. LOW LATENCY (10.-15ms)&lt;/div&gt;&lt;div&gt;3. CAP THEOREM&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; (FIRST OF ALL OUR APPLICATION SHOULD BE AVAILABLE TO THE USER AND THEN SHOULD BE CONSISTENT)&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;4. RELIABLE ---&amp;gt; ENTIRE MESSAGE SHOULD BE DELIVERED&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;5. SCALABLE AND SECURE&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="700" x="940" y="320" as="geometry" />
        </mxCell>
