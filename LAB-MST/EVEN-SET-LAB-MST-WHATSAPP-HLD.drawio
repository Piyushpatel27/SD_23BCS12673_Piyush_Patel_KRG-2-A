        <mxCell id="KBRIS76X-1Ge197PzryG-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="EVEN-SET" vertex="1">
